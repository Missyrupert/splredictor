# ── Vercel Postgres ────────────────────────────────────────────────────────
# Required for all storage (predictions, results, settings).
# On Vercel: added automatically when you connect a Postgres/Neon database.
# For local dev: copy from the Vercel dashboard → Storage → your DB → .env.local tab,
# then paste below.

POSTGRES_URL=

# These are set automatically by Vercel alongside POSTGRES_URL.
# You only need them locally if your DB client requires them separately.
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
